<idea-plugin>
    <id>com.github.brannow.phpstormmcp</id>
    <name>PhpStorm MCP</name>
    <vendor>brannow</vendor>
    <description><![CDATA[
        MCP server plugin for PhpStorm — exposes IDE debugging features to AI agents.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xdebugger</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
            id="PhpStorm MCP"
            displayType="BALLOON"/>
        <statusBarWidgetFactory
            id="McpStatusWidget"
            implementation="com.github.brannow.phpstormmcp.statusbar.McpStatusWidgetFactory"
            order="after Encoding"/>
    </extensions>
</idea-plugin>
